{
  "name": "playwright-with-nodejs",
  "version": "1.0.0",
  "description": "Production-ready API for web scraping with Playwright and testing",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "docker:build": "docker build -t playwright-api:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env playwright-api:latest",
    "docker:compose": "docker-compose up",
    "zip": "npm run build && npm run zip:create",
    "zip:create": "node -e \"const archiver=require('archiver');const fs=require('fs');const output=fs.createWriteStream('playwright-with-nodejs.zip');const archive=archiver('zip',{zlib:{level:9}});archive.pipe(output);const addDir=(path,name)=>fs.existsSync(path)&&archive.directory(path,name);const addFile=(path)=>fs.existsSync(path)&&archive.file(path,{name:path});['dist','src','tests','docker'].forEach((dir)=>addDir(dir,dir));['package.json','package-lock.json','tsconfig.json','.env.example','.eslintrc.json','.prettierrc.json','Dockerfile','docker-compose.yml','.dockerignore','.gitignore','README.md','playwright.config.ts'].forEach(addFile);archive.finalize();\""
  },
  "keywords": [
    "playwright",
    "scraping",
    "api",
    "express",
    "typescript",
    "testing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "playwright": "^1.40.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.8",
    "@types/compression": "^1.7.5",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "prettier": "^3.1.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@playwright/test": "^1.40.0",
    "archiver": "^6.0.0"
  }
}
